# ART — Environment Variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore and will never be committed.

# ── LLM Provider ────────────────────────────────────────────
# Choose one: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# ── API Keys ─────────────────────────────────────────────────
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=

# ── GitHub Ingestion ─────────────────────────────────────────
# Personal access token — needed for private repos and higher rate limits.
# Create one at: https://github.com/settings/tokens (read:user, repo scopes)
GITHUB_TOKEN=

# Default GitHub username for `ingest github` (optional — can type it in chat)
GITHUB_USERNAME=

# ── Per-role model overrides (optional) ──────────────────────
# Defaults shown. Uncomment and change to override.
# CHAT_MODEL=claude-haiku-4-5-20251001
# EXTRACT_MODEL=claude-haiku-4-5-20251001
# TAILOR_MODEL=claude-sonnet-4-6

