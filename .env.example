# ART — Environment Variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore and will never be committed.

# ── LLM Provider ────────────────────────────────────────────
# Choose one: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# ── API Keys ─────────────────────────────────────────────────
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=

# ── GitHub OAuth App (recommended) ───────────────────────────
# Register an OAuth App at: https://github.com/settings/developers
# Authorization callback URL: https://<your-domain>/api/auth/github/callback
# (Use http://localhost:8000/api/auth/github/callback for local dev)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── GitHub Ingestion (fallback) ───────────────────────────────
# Personal access token — only needed if not using OAuth above.
# Create one at: https://github.com/settings/tokens (read:user, repo scopes)
GITHUB_TOKEN=

# Default GitHub username for `ingest github` (optional — can type it in chat)
GITHUB_USERNAME=

# ── Database (optional) ──────────────────────────────────────
# Leave unset to use local SQLite (~/.art/art.db).
# Set to a Supabase PostgreSQL URL to use the cloud database.
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# DATABASE_URL=

# Docker: override the local data directory (default: ~/.art)
# ART_DATA_DIR=/data

# ── Supabase Auth (Phase 2 — required for cloud multi-user) ──
# When these are set, ALL authentication goes through Supabase (email + password)
# and no password is stored locally. When absent, the app uses an offline local
# fallback for dev/tests only. Password recovery requires Supabase.
# SUPABASE_URL=https://[PROJECT-REF].supabase.co
# SUPABASE_ANON_KEY=eyJ...              # safe to expose to the client
# SUPABASE_SERVICE_ROLE_KEY=eyJ...      # backend only — never expose to clients
# SUPABASE_JWT_SECRET=                  # Supabase → Settings → API → JWT Secret

# Public origin of the app, used to build the password-reset link's redirect
# target. Defaults to the incoming request's origin if unset (fine for local dev).
# In Supabase → Authentication → URL Configuration, add <APP_BASE_URL>/reset-password
# to the allowed Redirect URLs.
# APP_BASE_URL=https://artie-resume-tailoring.fly.dev

# ── Web API ───────────────────────────────────────────────────
# Required for secure session cookies in the FastAPI web server.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=

# Set to any non-empty value to enable CORS for local Vite dev server (:5173)
# DEV_MODE=1

# ── Per-role model overrides (optional) ──────────────────────
# Defaults shown. Uncomment and change to override.
# CHAT_MODEL=claude-haiku-4-5-20251001
# EXTRACT_MODEL=claude-haiku-4-5-20251001
# TAILOR_MODEL=claude-sonnet-4-6

